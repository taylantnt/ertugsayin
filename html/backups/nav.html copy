<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Animated Navigation</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: system-ui, -apple-system, sans-serif;
      background: linear-gradient(45deg, #f3ec78, #af4261);
    }

    .header-card {
      position: relative;
      padding: 1em;
      background: var(--header-fill, rgba(255, 255, 255, 0.3));
      border-radius: 1em;
      transition: all 0.25s ease-out;
    }

    .header-menu {
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.25s ease-out;
    }

    .header-toggle {
      position: absolute;
      width: 100%;
      height: 100%;
      top: 0;
      right: 0;
      pointer-events: none;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .header-toggle label {
      pointer-events: auto;
      cursor: pointer;
    }

    .header-menu-list {
      margin: 0;
      padding: 0;
      opacity: 0;
      list-style: none;
      display: flex;
      flex-direction: column;
      align-items: start;
      justify-content: start;
      transition: margin 0.25s ease-out, padding 0.25s ease-out, opacity 0.4s ease-out;
    }

    .header-menu-item {
      display: grid;
      place-items: center;
      opacity: 1;
      transition: opacity 0.3s ease-out;
      padding: 0.5em;
      font-size: 1.2em;
      color: #333;
      text-decoration: none;
    }

    .header-menu-list:has(.header-menu-item:hover) .header-menu-item:not(:hover) {
      opacity: 0.5;
    }

    .header-card:has(#menu-toggle:checked) {
      --padding: 1em;
      --header-fill: rgba(255, 255, 255, 0.5);
      -webkit-backdrop-filter: blur(12px);
      backdrop-filter: blur(12px);
    }

    .header-card:has(#menu-toggle:checked) .header-menu {
      grid-template-rows: 1fr;
    }

    .header-card:has(#menu-toggle:checked) .header-menu-list {
      margin: 3em 0 0;
      opacity: 1;
    }

    .header-menu > * {
      overflow: hidden;
    }

    .header-card:hover {
      -webkit-backdrop-filter: blur(12px);
      backdrop-filter: blur(12px);
      box-shadow: 0 0 1em 0.25em rgba(255, 255, 255, 0.95) inset, 0 0.5em 0.75em -0.125em rgba(0, 0, 0, 0.2);
    }

    #menu-toggle {
      display: none;
    }

    .menu-icon {
      width: 24px;
      height: 24px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      cursor: pointer;
    }

    .menu-icon span {
      width: 100%;
      height: 2px;
      background-color: #333;
      transition: transform 0.25s ease-out;
    }

    #menu-toggle:checked ~ .header-toggle .menu-icon span:first-child {
      transform: translateY(11px) rotate(45deg);
    }

    #menu-toggle:checked ~ .header-toggle .menu-icon span:last-child {
      transform: translateY(-11px) rotate(-45deg);
    }
  </style>
</head>
<body>
  <div class="header-card">
    <input type="checkbox" id="menu-toggle">
    <div class="header-menu">
      <div class="header-menu-list">
        <a href="#" class="header-menu-item">Home</a>
        <a href="#" class="header-menu-item">About</a>
        <a href="#" class="header-menu-item">Services</a>
        <a href="#" class="header-menu-item">Portfolio</a>
        <a href="#" class="header-menu-item">Contact</a>
      </div>
    </div>
    <div class="header-toggle">
      <label for="menu-toggle" class="menu-icon">
        <span></span>
        <span></span>
      </label>
    </div>
  </div>
</body>
</html>